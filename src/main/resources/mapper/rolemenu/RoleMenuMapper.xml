                <foreach collection="roleMenus" item="roleMenu" separator=" ">
                    <choose>
                        <when test="roleMenu.delYn != null">
                            WHEN (role_id = #{roleMenu.roleId}
                                  AND menu_id = #{roleMenu.menuId})
                            THEN #{roleMenu.delYn}
                        </when>
                        <otherwise>
                            WHEN (role_id = #{roleMenu.roleId}
                                  AND menu_id = #{roleMenu.menuId})
                            THEN del_yn
                        </otherwise>
                    </choose>
                </foreach>
                ELSE del_yn
            END,
            chg_id = CASE
                <foreach collection="roleMenus" item="roleMenu" separator=" ">
                    <choose>
                        <when test="roleMenu.chgId != null">
                            WHEN (role_id = #{roleMenu.roleId}
                                  AND menu_id = #{roleMenu.menuId})
                            THEN #{roleMenu.chgId}
                        </when>
                        <otherwise>
                            WHEN (role_id = #{roleMenu.roleId}
                                  AND menu_id = #{roleMenu.menuId})
                            THEN chg_id
                        </otherwise>
                    </choose>
                </foreach>
                ELSE chg_id
            END,
            chg_dt = CASE
                <foreach collection="roleMenus" item="roleMenu" separator=" ">
                    <choose>
                        <when test="roleMenu.chgDt != null">
                            WHEN (role_id = #{roleMenu.roleId}
                                  AND menu_id = #{roleMenu.menuId})
                            THEN COALESCE(#{roleMenu.chgDt}, NOW())
                        </when>
                        <otherwise>
                            WHEN (role_id = #{roleMenu.roleId}
                                  AND menu_id = #{roleMenu.menuId})
                            THEN NOW()
                        </otherwise>
                    </choose>
                </foreach>
                ELSE chg_dt
            END,
            del_id = CASE
                <foreach collection="roleMenus" item="roleMenu" separator=" ">
                    <choose>
                        <when test="roleMenu.delId != null">
                            WHEN (role_id = #{roleMenu.roleId}
                                  AND menu_id = #{roleMenu.menuId})
                            THEN #{roleMenu.delId}
                        </when>
                        <otherwise>
                            WHEN (role_id = #{roleMenu.roleId}
                                  AND menu_id = #{roleMenu.menuId})
                            THEN del_id
                        </otherwise>
                    </choose>
                </foreach>
                ELSE del_id
            END,
            del_dt = CASE
                <foreach collection="roleMenus" item="roleMenu" separator=" ">
                    <choose>
                        <when test="roleMenu.delDt != null">
                            WHEN (role_id = #{roleMenu.roleId}
                                  AND menu_id = #{roleMenu.menuId})
                            THEN COALESCE(#{roleMenu.delDt}, NOW())
                        </when>
                        <otherwise>
                            WHEN (role_id = #{roleMenu.roleId}
                                  AND menu_id = #{roleMenu.menuId})
                            THEN NOW()
                        </otherwise>
                    </choose>
                </foreach>
                ELSE del_dt
            END
        WHERE 
            (role_id, menu_id) IN 
            <foreach collection="roleMenus" item="roleMenu" open="(" close=")" separator=",">
                (#{roleMenu.roleId}, #{roleMenu.menuId})
            </foreach>
    </update>
</mapper>