<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" 
    "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.common.auth.user.mapper.UserMapper">
    <resultMap id="UserResultMap" type="com.common.auth.user.domain.User">
        <id property="memberId" column="user_id" />
        <result property="userName" column="user_name"/>
        <result property="email" column="email"/>
        <result property="passwordHash" column="password_hash"/>
        <result property="telNo" column="telNo"/>
        <result property="userStatusCd" column="user_status_cd"/>
        <result property="lastLoginDt" column="last_login_dt"/>
        <result property="loginFailCnt" column="login_fail_cnt"/>
        <result property="regId" column="reg_id" />
        <result property="regDt" column="reg_dt"/>
        <result property="chgId" column="chg_id" />
        <result property="chgDt" column="chg_dt"/>
        <result property="delId" column="del_id" />
        <result property="delDt" column="del_dt"/>
        <result property="delYn" column="del_Yn"/>
    </resultMap>
    
    <sql id="userColumns">
        user_id, user_name, email, password_hash, telNo, user_status_cd,
        last_login_dt, login_fail_cnt, reg_id, reg_dt, chg_id, chg_dt, del_id, del_dt, del_yn
    </sql>
    
    <select id="selectUserByLoginId" resultMap="UserResultMap">
        SELECT 
            <include refid="userColumns" />
        FROM 
            user
        WHERE 
            member_id = #{memberId}
        AND 
            del_yn = 'N'
    </select>
    
    <select id="selectUserByMemberId" resultMap="UserResultMap">
        SELECT 
            <include refid="userColumns" />
        FROM 
            user
        WHERE 
            member_id = #{memberId}
        AND 
            del_yn = 'N'
    </select>
    
    <select id="selectAllUsers" resultMap="UserResultMap">
        SELECT 
            <include refid="userColumns" />
        FROM 
            user
        ORDER BY 
            email
    </select>
    
    <insert id="insertUser" parameterType="com.jeil.delivery.domain.MemberDTO">
        INSERT INTO 
            user (
                user_id, 
                user_name, 
                email, 
                password_hash, 
                telNo,
                user_status_cd, 
                last_login_dt, 
                login_fail_cnt, 
                reg_id,
                reg_dt,
                chg_id, 
                chg_dt, 
                del_yn
        )
        VALUES (
            COALESCE(#{userId}, gen_random_uuid()),
            #{userName},
            #{email},
            #{passwordHash},
            #{telNo},
            #{userStatusCd},
            #{lastLoginDt},
            #{loginFailCnt},
            COALESCE(#{regId}, gen_random_uuid()),
            COALESCE(#{regDt}, NOW()),
            COALESCE(#{chgId}, gen_random_uuid()),
            COALESCE(#{chgDt}, NOW()),
            #{delYn}
        )
    </insert>
    
    <update id="updateUser" parameterType="com.jeil.delivery.domain.MemberDTO">
        UPDATE 
            user
        SET
            user_name = #{userName},
            <!-- email은 업데이트 불가 -->
            <!-- email = #{email}, -->
            password_hash = #{passwordHash},
            telNo = #{telNo},
            user_status_cd = #{userStatusCd},
            last_login_dt = #{lastLoginDt},
            login_fail_cnt = #{loginFailCnt},
            chg_id = #{chgId},
            chg_dt = NOW(),
            del_id = #{delId},
            del_dt = #{delDt},
            del_yn = #{delYn}
        WHERE 
            member_id = #{memberId}
    </update>
    
    <delete id="deleteUserByUserId">
        DELETE FROM 
            user
        WHERE 
            member_id = #{memberId}
    </delete>
    
    <select id="selectExistsByUserEmail" resultType="boolean">
        SELECT 
            EXISTS(
                SELECT 
                    1 
                FROM 
                    user
                WHERE 
                    email = #{email}
            )
    </select>
    
    <select id="selectCountUsers" resultType="int">
        SELECT 
            COUNT(*) 
        FROM 
            user
    </select>
    
