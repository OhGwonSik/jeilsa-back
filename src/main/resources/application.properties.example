spring.application.name=jeil
server.port=8080

# DB 설정
spring.datasource.hikari.driver-class-name=net.sf.log4jdbc.sql.jdbcapi.DriverSpy
spring.datasource.hikari.connection-timeout=600000
spring.datasource.hikari.maximum-pool-size=15
spring.datasource.hikari.minimum-idle=2

# JWT 설정
jwt.accessToken=your-access-token-secret
jwt.accessToken-expire-time=604800
jwt.refreshToken=your-refresh-token-secret
jwt.refreshToken-expire-time=604800
jwt.issuer=jeil-delivery-service
jwt.audience=jeil

# Mail 설정
spring.mail.host=your-smtp-host
spring.mail.port=587
spring.mail.username=your-smtp-username
spring.mail.password=your-smtp-password
mail.from.address=your-email@example.com

# DB 접속 정보
database.host=your-db-host
database.port=3306
ssh.host=your-ssh-host
ssh.port=22
ssh.username=your-ssh-username
ssh.password=your-ssh-password
